        "operation": "sendMessage",
        "text": "=✅ *Campaña Aprobada*\n\nEl manifest.json de la campaña del {{ $json.date }} ha sido actualizado exitosamente a 'ready_to_publish'."
      },
      "webhookId": "e7e37d6d-0faf-425a-b095-41e3f8fba334"
    },
    {
      "id": "code-rejected-status-1",
      "name": "Set Status Rejected",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1950,
        300
      ],
      "parameters": {
        "jsCode": "const manifestNode = $('Parse manifest & copy').first().json;\nconst manifest = manifestNode.manifest;\nmanifest.status = 'review_failed';\n\nreturn [{\n  json: {\n    manifest,\n    manifestContent: JSON.stringify(manifest, null, 2),\n    githubFilePath: manifestNode.githubFilePath,\n    repoOwner: manifestNode.repoOwner,\n    repoName: manifestNode.repoName,\n    branch: manifestNode.branch,\n    date: manifestNode.date\n  }\n}];"
      }
    },
