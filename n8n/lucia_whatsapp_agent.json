      "id": "ab7c8e9b-381a-45c1-8d2b-ff27b2cbb1d3",
      "name": "Guardar Lead Sub-Workflow Tool",
      "parameters": {
        "description": "Utiliza esta herramienta únicamente cuando el usuario te haya proporcionado sus datos de contacto completos (Nombre, Correo, Teléfono) y la Materia de interés, para registrarlos en el sistema Supabase y GoHighLevel.",
        "inputSchema": "{\\n  \\\"type\\\": \\\"object\\\",\\n  \\\"properties\\\": {\\n    \\\"nombre\\\": {\\n      \\\"type\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"Nombre completo del lead\\\"\\n    },\\n    \\\"email\\\": {\\n      \\\"type\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"Correo electrónico de contacto\\\"\\n    },\\n    \\\"telefono\\\": {\\n      \\\"type\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"Número de teléfono del contacto\\\"\\n    },\\n    \\\"materia\\\": {\\n      \\\"type\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"Materia que necesita reforzar\\\"\\n    },\\n    \\\"nivel\\\": {\\n      \\\"type\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"Nivel académico del estudiante (Primaria, Secundaria, Bachillerato, Universidad)\\\"\\n    },\\n    \\\"descripcion\\\": {\\n      \\\"type\\\": \\\"string\\\",\\n      \\\"description\\\": \\\"Breve descripción de la necesidad académica\\\"\\n    }\\n  },\\n  \\\"required\\\": [\\\"nombre\\\", \\\"email\\\", \\\"telefono\\\", \\\"materia\\\"]\\n}",
        "name": "guardar_lead",
