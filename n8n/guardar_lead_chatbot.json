            {
              "column": "nombre",
              "value": "={{$json.nombre}}"
            },
            {
              "column": "email",
              "value": "={{$json.email}}"
            },
            {
              "column": "telefono",
              "value": "={{$json.telefono}}"
            },
            {
              "column": "materia",
              "value": "={{$json.materia}}"
            },
            {
              "column": "nivel",
              "value": "={{$json.nivel}}"
            },
            {
              "column": "descripcion",
              "value": "={{$json.descripcion || 'Sin descripción'}}"
