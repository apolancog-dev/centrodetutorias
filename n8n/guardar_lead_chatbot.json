{
  "name": "Guardar Lead desde Chatbot",
  "nodes": [
    {
      "parameters": {},
      "id": "e44d32a1-fa0b-4bd2-8e10-ff99c82abdd3",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        200,
        240
      ]
    },
    {
      "parameters": {
